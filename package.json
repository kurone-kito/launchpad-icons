{
  "name": "@kurone-kito/launchpad-icons",
  "version": "0.1.0",
  "private": true,
  "description": "the icons VPM asset like the VRChat LaunchPad for the VRChat and Web",
  "keywords": [
    "Icons",
    "LaunchPad",
    "VRChat"
  ],
  "homepage": "https://github.com/kurone-kito/launchpad-icons#readme",
  "bugs": "https://github.com/kurone-kito/launchpad-icons/issues",
  "repository": "github:kurone-kito/launchpad-icons",
  "license": "CC BY-NC 4.0",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "files": [],
  "scripts": {
    "build": "vinxi build",
    "clean": "rimraf -g .eslintcache .output .vinxi \"*.tgz\" \"*.tsbuildinfo\" src/dynamic.json \"node_modules/.cache/**/*\"",
    "dev": "vinxi dev",
    "prebuild": "pnpm run prebuild:icons && pnpm run prebuild:json",
    "prebuild:icons": "symlink-dir Packages/black.kit.launchpadicons/Runtime public/icons",
    "prebuild:json": "node ./scripts/createDynamicJson.mjs",
    "predev": "pnpm run prebuild",
    "prepare": "husky && pnpm run prebuild",
    "preserve": "pnpm run prebuild",
    "prestart": "pnpm run prebuild",
    "lint": "pnpm run \"/lint:.*:check/\"",
    "lint:cspell:check": "cspell lint --no-progress --show-suggestions -u \"./**/*\"",
    "lint:eslint:check": "eslint --cache --cache-location node_modules/.cache/eslint/ --cache-strategy=content -f codeframe \"./**/*\"",
    "lint:eslint:fix": "pnpm run lint:eslint:check --fix",
    "lint:fix": "pnpm run \"/lint:.*:fix/\"",
    "lint:oxlint:check": "oxlint .",
    "lint:oxlint:fix": "oxlint --fix .",
    "lint:prettier:check": "pnpm run prettier -cu",
    "lint:prettier:fix": "pnpm run prettier -uw",
    "prettier": "prettier --cache --log-level=warn \"./**/*\"",
    "serve": "vinxi serve --dir .output/public",
    "start": "vinxi start",
    "test": "pnpm run lint"
  },
  "dependencies": {
    "@solidjs/router": "^0.13.6",
    "@solidjs/start": "^1.0.2",
    "solid-js": "^1.8.18",
    "tw-elements": "^2.0.0"
  },
  "prettier": "@kurone-kito/prettier-config",
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@cspell/cspell-types": "^8.9.1",
    "@cspell/eslint-plugin": "^8.9.1",
    "@kurone-kito/commitlint-config": "^0.12.0",
    "@kurone-kito/cspell-config": "^0.12.0",
    "@kurone-kito/eslint-config-base": "0.12.0",
    "@kurone-kito/lint-staged-config": "^0.12.0",
    "@kurone-kito/prettier-config": "^0.12.0",
    "@kurone-kito/typescript-config": "^0.12.0",
    "@opentelemetry/api": "~1.8.0",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "autoprefixer": "^10.4.19",
    "cspell": "^8.9.1",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-formatter-codeframe": "^7.32.1",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-editorconfig": "^4.0.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.5.0",
    "eslint-plugin-json": "^4.0.0",
    "eslint-plugin-markdown": "^5.0.0",
    "eslint-plugin-markdownlint": "^0.6.0",
    "eslint-plugin-n": "^17.9.0",
    "eslint-plugin-oxlint": "^0.5.0",
    "eslint-plugin-yaml": "^1.0.2",
    "gh-pages": "^6.1.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "oxlint": "^0.5.1",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "symlink-dir": "^6.0.0",
    "tailwindcss": "^3.4.4",
    "typescript": "~5.5.2",
    "typescript-eslint-language-service": "^5.0.5",
    "vinxi": "^0.3.12"
  },
  "packageManager": "pnpm@9.4.0+sha512.f549b8a52c9d2b8536762f99c0722205efc5af913e77835dbccc3b0b0b2ca9e7dc8022b78062c17291c48e88749c70ce88eb5a74f1fa8c4bf5e18bb46c8bd83a",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
