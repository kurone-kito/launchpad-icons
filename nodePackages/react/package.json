{
  "name": "@kurone-kito/launchpad-icons-react",
  "version": "0.6.0-alpha.2",
  "description": "the icons like the VRChat for Node.js ecosystem with the React",
  "keywords": [
    "components",
    "icons",
    "LaunchPad",
    "React",
    "SVG",
    "VRChat"
  ],
  "homepage": "https://github.com/kurone-kito/launchpad-icons#readme",
  "bugs": "https://github.com/kurone-kito/launchpad-icons/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurone-kito/launchpad-icons.git",
    "directory": "nodePackages/react"
  },
  "license": "CC-BY-NC-4.0",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm run \"/^prebuild:res:.+/\" && pnpm run prebuild:code",
    "build": "tsc",
    "clean": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" dist LICENSE node_modules/.cache assets src/index.mts",
    "prepack": "pnpm run clean && pnpm run build",
    "prebuild:code": "lib-codeBuilder react assets > src/index.tsx",
    "prebuild:res:icons": "symlink-dir ../../Packages/black.kit.launchpadicons/Runtime assets",
    "prebuild:res:license": "cpy --flat ../../LICENSE .",
    "prepare": "pnpm run prebuild:res:icons",
    "prestart": "pnpm run prebuild",
    "start": "tsc --watch"
  },
  "devDependencies": {
    "@kurone-kito/launchpad-icons-builder": "workspace:^",
    "@kurone-kito/typescript-config": "^0.15.0-alpha.2",
    "@types/react": "^18.3.3",
    "cpy-cli": "^5.0.0",
    "react": "^18.3.1",
    "rimraf": "^5.0.10",
    "symlink-dir": "^6.0.1",
    "typescript": "~5.5.4"
  },
  "peerDependencies": {
    "react": ">=18.x.x"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
